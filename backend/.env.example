POSTGRES_DB=tknt
POSTGRES_USER=tknt
POSTGRES_PASSWORD=tknt_password
POSTGRES_PORT_HOST=5432

TKNT_API_PORT=8000
TKNT_API_KEY=change-me
TKNT_LOG_LEVEL=INFO
TKNT_SHARED_INVENTORY_TENANT_ID=demo_tenant
TKNT_ENABLE_DEMO_INVENTORY=1
TKNT_AUTO_LOAD_DEMO_DATA=0
TKNT_CATALOG_API_BASE_URL=https://auto-furniture-api2.a-star.group
TKNT_CATALOG_ASSET_BASE_URL=https://storage.mazig.io
TKNT_CATALOG_API_PAGE_LIMIT=500
TKNT_CATALOG_API_MAX_PAGES=20
TKNT_CATALOG_API_TIMEOUT_SECONDS=15

#OpenAI mode:
OPENAI_API_KEY=replace-with-openai-key
OPENAI_BASE_URL=
OPENAI_AZURE=0
OPENAI_API_VERSION=2024-08-01-preview
OPENAI_PRIMARY_MODEL=gpt-5.4-mini
OPENAI_HELPER_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_AGENT_MODEL=

# Azure OpenAI mode:
# Set OPENAI_AZURE=1, endpoint, key, and deployment names.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_PRIMARY_DEPLOYMENT=
AZURE_OPENAI_HELPER_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

OPENAI_PUBLIC_KEY=your-application-public-key
OPENAI_PRIVATE_KEY_FILE=private_key.enc

GEMINI_API_KEY=
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_BASE_URL=

TKNT_SEMANTIC_ADAPTIVE_LLM=1
TKNT_STYLE_POLICY_REQUIRE_LLM=1